---
const { t } = Astro.props;

const industries = [
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>`, label: t.trustLogos.items[0] },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`, label: t.trustLogos.items[1] },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`, label: t.trustLogos.items[2] },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`, label: t.trustLogos.items[3] },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>`, label: t.trustLogos.items[4] },
  { icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`, label: t.trustLogos.items[5] },
];
---

<section class="trust-logos-section" aria-label={t.trustLogos.label}>
  <div class="container">
    <p class="tl-label animate-on-scroll">{t.trustLogos.label}</p>
    <div class="tl-grid animate-on-scroll" style="animation-delay: 0.1s">
      {industries.map((item) => (
        <div class="tl-item">
          <span class="tl-icon" set:html={item.icon} />
          <span class="tl-name">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-logos-section {
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--border-dark);
  }
  .tl-label {
    text-align: center;
    font-size: var(--fs-caption);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: var(--space-lg);
  }
  .tl-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md) var(--space-xl);
  }
  .tl-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: var(--fs-small);
    font-weight: 500;
    transition: color var(--transition-medium);
    opacity: 0.6;
  }
  .tl-item:hover { opacity: 1; color: var(--text-secondary); }
  .tl-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .tl-icon :global(svg) { width: 100%; height: 100%; }

  @media (min-width: 768px) {
    .tl-grid { flex-wrap: nowrap; }
  }
</style>
