---
const { t } = Astro.props;

const benefitKeys = ['privacy', 'realtime', 'price', 'offline'];

const benefitIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2z"/><path d="M12 6v6l4 2"/><line x1="2" y1="12" x2="4" y2="12"/><line x1="20" y1="12" x2="22" y2="12"/></svg>`,
];
---

<section class="benefits-section" id="benefits">
  <div class="benefits-bg" aria-hidden="true"></div>
  <div class="container benefits-container">
    <div class="benefits-header animate-on-scroll">
      <span class="benefits-badge">{t.benefits.badge}</span>
      <h2 class="benefits-title">
        {t.benefits.title} <em class="benefits-accent">{t.benefits.titleAccent}</em>
      </h2>
      <p class="benefits-subtitle">{t.benefits.subtitle}</p>
    </div>
    <div class="benefits-grid">
      {benefitKeys.map((key, i) => (
        <div class="benefit-card animate-on-scroll" style={`animation-delay: ${i * 0.1}s`}>
          <div class="benefit-icon" set:html={benefitIcons[i]} />
          <h3 class="benefit-title">{t.benefits.items[key].title}</h3>
          <p class="benefit-desc">{t.benefits.items[key].description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .benefits-section {
    position: relative;
    overflow: hidden;
    padding: var(--space-3xl) 0;
  }
  .benefits-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg,
      rgba(139, 92, 246, 0.15) 0%,
      rgba(168, 139, 250, 0.08) 30%,
      rgba(236, 72, 153, 0.10) 70%,
      rgba(139, 92, 246, 0.12) 100%
    );
    border-top: 1px solid rgba(139, 92, 246, 0.2);
    border-bottom: 1px solid rgba(139, 92, 246, 0.2);
  }
  .benefits-bg::before {
    content: '';
    position: absolute;
    top: -150px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(139,92,246,0.2) 0%, transparent 70%);
    filter: blur(60px);
  }
  .benefits-container { position: relative; z-index: 1; }

  .benefits-header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }
  .benefits-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    font-size: var(--fs-caption);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 100px;
    background: rgba(255,255,255,0.1);
    color: var(--text-primary);
    border: 1px solid rgba(255,255,255,0.15);
    margin-bottom: var(--space-md);
  }
  .benefits-title {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }
  .benefits-accent {
    font-style: italic;
    background: linear-gradient(135deg, #A78BFA, #EC4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .benefits-subtitle {
    color: var(--text-secondary);
    font-size: var(--fs-h3);
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ─── Benefits Grid ─── */
  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
  }
  @media (min-width: 640px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .benefits-grid { grid-template-columns: repeat(4, 1fr); } }

  .benefit-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 20px;
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    backdrop-filter: blur(12px);
    transition: transform var(--transition-medium), background var(--transition-medium), box-shadow var(--transition-medium);
  }
  .benefit-card:hover {
    transform: translateY(-6px);
    background: rgba(255,255,255,0.07);
    box-shadow: 0 20px 50px rgba(0,0,0,0.2);
  }
  .benefit-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto var(--space-md);
    background: rgba(139,92,246,0.15);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #A78BFA;
    transition: transform var(--transition-medium);
  }
  .benefit-card:hover .benefit-icon { transform: scale(1.1); }
  .benefit-icon :global(svg) { width: 24px; height: 24px; }
  .benefit-title {
    font-size: var(--fs-h3);
    font-weight: 700;
    margin-bottom: var(--space-xs);
    color: var(--text-primary);
  }
  .benefit-desc {
    font-size: var(--fs-small);
    color: var(--text-secondary);
    line-height: 1.7;
  }
</style>
