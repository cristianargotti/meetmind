---
const { t } = Astro.props;

const useCaseKeys = ['standup', 'planning', 'client', 'interview', 'workshop'];

const useCaseIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M3 9h6"/><path d="M3 15h6"/><path d="M13 8h5"/><path d="M13 12h5"/><path d="M13 16h5"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="7" r="4"/><path d="M20 21a8 8 0 10-16 0"/><path d="M12 11v4"/><path d="M10 15h4"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>`,
];

const useCaseColors = ['#8B5CF6', '#06D6A0', '#F97316', '#EC4899', '#3B82F6'];
---

<section class="section use-cases-section" id="use-cases">
  <div class="container">
    <div class="section-header animate-on-scroll">
      <span class="badge">{t.useCases.badge}</span>
      <h2 class="section-title" style="margin-top: var(--space-md);">{t.useCases.title}</h2>
      <p class="section-subtitle">{t.useCases.subtitle}</p>
    </div>

    <!-- Tab buttons -->
    <div class="uc-tabs animate-on-scroll" style="animation-delay: 0.1s" role="tablist">
      {useCaseKeys.map((key, i) => (
        <button
          class={`uc-tab ${i === 0 ? 'active' : ''}`}
          data-tab={key}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
          style={`--tab-color: ${useCaseColors[i]}`}
        >
          <span class="uc-tab-icon" set:html={useCaseIcons[i]} />
          <span class="uc-tab-label">{t.useCases.cases[key].tabLabel}</span>
        </button>
      ))}
    </div>

    <!-- Tab panels -->
    <div class="uc-panels">
      {useCaseKeys.map((key, i) => (
        <div
          class={`uc-panel animate-on-scroll glass-card ${i === 0 ? 'active' : ''}`}
          data-panel={key}
          style={`animation-delay: 0.2s; --panel-color: ${useCaseColors[i]}`}
          role="tabpanel"
        >
          <div class="uc-panel-left">
            <div class="uc-panel-icon" style={`background: color-mix(in srgb, ${useCaseColors[i]} 12%, transparent); color: ${useCaseColors[i]}`} set:html={useCaseIcons[i]} />
            <h3 class="uc-panel-title">{t.useCases.cases[key].title}</h3>
            <p class="uc-panel-desc">{t.useCases.cases[key].description}</p>
            <ul class="uc-benefits">
              {(t.useCases.cases[key].benefits as string[]).map((b: string) => (
                <li class="uc-benefit-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {b}
                </li>
              ))}
            </ul>
          </div>
          <div class="uc-panel-right">
            <div class="uc-phone-mini">
              <div class="uc-phone-screen">
                <div class="uc-phone-header">
                  <div class="uc-phone-dot" style={`background: ${useCaseColors[i]}`}></div>
                  <span class="uc-phone-title">{t.useCases.cases[key].mockTitle}</span>
                  <span class="uc-live-badge">LIVE</span>
                </div>
                <div class="uc-phone-wave">
                  {[8,14,6,18,10,16,7,20,12].map((h, wi) => (
                    <div class="uc-wave-bar" style={`--h: ${h}px; --d: ${wi * 0.08}s; --wc: ${useCaseColors[i]}`}></div>
                  ))}
                </div>
                <div class="uc-phone-lines">
                  <div class="uc-line" style={`width: 75%; background: color-mix(in srgb, ${useCaseColors[i]} 30%, transparent)`}></div>
                  <div class="uc-line" style="width: 55%"></div>
                  <div class="uc-line" style={`width: 85%; background: color-mix(in srgb, ${useCaseColors[i]} 20%, transparent)`}></div>
                  <div class="uc-line" style="width: 40%"></div>
                  <div class="uc-line" style="width: 65%"></div>
                </div>
                <div class="uc-phone-notif" style={`border-color: color-mix(in srgb, ${useCaseColors[i]} 30%, transparent)`}>
                  <span class="uc-notif-dot" style={`background: ${useCaseColors[i]}`}></span>
                  <span class="uc-notif-text">{t.useCases.cases[key].mockNotif}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .use-cases-section { position: relative; }

  /* ─── Tabs ─── */
  .uc-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    justify-content: center;
    margin-bottom: var(--space-xl);
  }
  .uc-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 100px;
    border: 1px solid var(--border-dark);
    background: transparent;
    color: var(--text-muted);
    font-size: var(--fs-small);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-medium);
    font-family: var(--font-family);
  }
  .uc-tab:hover {
    border-color: var(--tab-color);
    color: var(--text-primary);
    background: color-mix(in srgb, var(--tab-color) 8%, transparent);
  }
  .uc-tab.active {
    background: color-mix(in srgb, var(--tab-color) 15%, transparent);
    border-color: color-mix(in srgb, var(--tab-color) 50%, transparent);
    color: var(--text-primary);
    box-shadow: 0 0 20px color-mix(in srgb, var(--tab-color) 15%, transparent);
  }
  .uc-tab-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }
  .uc-tab-icon :global(svg) { width: 100%; height: 100%; }
  .uc-tab-label { white-space: nowrap; }

  /* ─── Panels ─── */
  .uc-panels { position: relative; }
  .uc-panel {
    display: none;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    padding: var(--space-2xl);
    border-color: color-mix(in srgb, var(--panel-color) 20%, transparent);
    box-shadow: 0 0 60px color-mix(in srgb, var(--panel-color) 5%, transparent);
  }
  .uc-panel.active { display: grid; }

  @media (min-width: 1024px) {
    .uc-panel { grid-template-columns: 1fr 1fr; align-items: center; }
  }

  /* ─── Panel Left ─── */
  .uc-panel-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
  }
  .uc-panel-icon :global(svg) { width: 28px; height: 28px; }
  .uc-panel-title {
    font-size: var(--fs-h2);
    font-weight: 800;
    margin-bottom: var(--space-sm);
    letter-spacing: -0.02em;
  }
  .uc-panel-desc {
    color: var(--text-secondary);
    font-size: var(--fs-body);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }
  .uc-benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .uc-benefit-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: var(--fs-small);
    color: var(--text-primary);
    font-weight: 500;
  }
  .uc-benefit-item svg { color: var(--panel-color); flex-shrink: 0; }

  /* ─── Phone Mockup ─── */
  .uc-panel-right { display: flex; justify-content: center; }
  .uc-phone-mini {
    width: 200px;
    height: 360px;
    background: linear-gradient(145deg, #1E2230, #08090D);
    border-radius: 32px;
    padding: 6px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
  .uc-phone-screen {
    width: 100%;
    height: 100%;
    background: #0F1117;
    border-radius: 26px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 12px 10px;
    gap: 10px;
  }
  .uc-phone-header {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .uc-phone-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .uc-phone-title { font-size: 10px; font-weight: 700; color: var(--text-primary); flex: 1; }
  .uc-live-badge {
    font-size: 7px;
    font-weight: 800;
    background: #EF4444;
    color: white;
    padding: 2px 5px;
    border-radius: 4px;
    animation: pulseLiveBadge 2s ease-in-out infinite;
  }
  @keyframes pulseLiveBadge { 0%,100%{opacity:1} 50%{opacity:0.5} }

  .uc-phone-wave {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 8px;
    background: rgba(139,92,246,0.04);
    border-radius: 8px;
  }
  .uc-wave-bar {
    width: 3px;
    height: var(--h);
    background: var(--wc);
    border-radius: 2px;
    opacity: 0.6;
    animation: ucWave 0.8s ease-in-out infinite;
    animation-delay: var(--d);
  }
  @keyframes ucWave { 0%,100%{transform:scaleY(0.3);opacity:0.3} 50%{transform:scaleY(1);opacity:0.9} }

  .uc-phone-lines {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .uc-line {
    height: 8px;
    background: rgba(255,255,255,0.06);
    border-radius: 4px;
  }
  .uc-phone-notif {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 10px;
    background: rgba(22,25,34,0.95);
    border: 1px solid;
    border-radius: 10px;
  }
  .uc-notif-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
  .uc-notif-text { font-size: 8px; color: var(--text-secondary); }
</style>

<script>
  function initUseCaseTabs() {
    const tabs = document.querySelectorAll('.uc-tab');
    const panels = document.querySelectorAll('.uc-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const key = (tab as HTMLElement).dataset.tab;
        tabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        panels.forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panel = document.querySelector(`.uc-panel[data-panel="${key}"]`);
        if (panel) panel.classList.add('active');
      });
    });
  }
  initUseCaseTabs();
</script>
